units metal
boundary p p p
dimension 3

atom_style full

variable step_calc equal 10000
variable step_calc_2 equal 50000
variable dump_dt equal 1

variable dump_write string dummp.lammpstrj

read_data au_dupl.data extra/atom/types 1
read_data au_int.data add append offset 1 0 0 0 0


mass 1 196.96657
mass 2 100000


pair_style lj/cut 10.0

pair_coeff 1 1 0.229 2.63
pair_coeff 1 2 0.229 2.63

neighbor 2.0 bin

kspace_style pppm 1.0e-4

dump dummp all atom 1 ${dump_write}
dump_modify dummp sort id

group ext type 1 
group int type 2
velocity ext create 300.0 123


minimize 1.0e-6 1.0e-6 1000 10000

dump_modify dummp every 100

fix T ext nvt temp 300.0 1000.0 0.05
fix Th h nvt temp 300 300 0.05
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.0005

run ${step_calc}

velocity ext create 1000.0 321

fix T ext nvt temp 1000.0 1000.0 0.05
fix Th h nvt temp 300 300 0.05
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.001

run ${step_calc_2}

velocity ext create 1000.0 213

fix T ext nvt temp 1000.0 300.0 0.05
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.0005

run ${step_calc}

group del_pot type 5
group del_pot type 6
delete_atoms group del_pot

velocity ext create 300.0 312

unfix T
fix T ext nvt temp 300.0 1000.0 0.05
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.0005

run ${step_calc}


velocity ext create 1000.0 1023

unfix T
fix T ext nvt temp 1000.0 1000.0 0.1
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.001

run ${step_calc_2}

velocity ext create 1000.0 1203

unfix T
fix T ext npt temp 1000.0 1000.0 0.05 iso 1 1 0.5
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.0005

run ${step_calc}


velocity ext create 1000.0 1302

unfix T
fix T ext npt temp 1000.0 1000.0 0.05 iso 1 1 0.5
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.001

run ${step_calc_2}

velocity ext create 1000.0 1230

unfix T
fix T ext npt temp 1000.0 0.1 0.05 iso 1 1 0.5
thermo_style custom step temp press etotal vol lx ly lz
thermo 100
timestep 0.0005

run ${step_calc_2}

dump_modify dummp every 1
minimize 1.0e-6 1.0e-6 1000 10000
